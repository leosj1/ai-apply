# OpenAI
OPENAI_API_KEY=sk-your-key-here

# Database (Turso/LibSQL)
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=your-token

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
CLERK_WEBHOOK_SECRET=whsec_xxx

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Resend (Email)
RESEND_API_KEY=re_xxx

# RapidAPI (JSearch job search)
RAPIDAPI_KEY=your-rapidapi-key-here

# Anthropic (Claude AI — preferred for auto-apply agent)
ANTHROPIC_API_KEY=sk-ant-xxx

# CAPTCHA Solving — smart routing picks the best provider per CAPTCHA type.
# CapSolver: https://capsolver.com — reCAPTCHA v2 (SmartRecruiters, Greenhouse)
CAPSOLVER_API_KEY=CAP-your-capsolver-key
# Anti-Captcha: https://anti-captcha.com — hCaptcha (Lever)
ANTICAPTCHA_API_KEY=your-anti-captcha-key
# 2Captcha: https://2captcha.com — reCAPTCHA fallback
TWOCAPTCHA_API_KEY=your-2captcha-api-key

# Gmail (for verification code retrieval in auto-apply)
GOOGLE_GMAIL_REFRESH_TOKEN=your-gmail-refresh-token

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
